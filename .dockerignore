# Keep the Docker build context small + reproducible (issue A.2 / #42).
# The build stage runs `yarn install` + `yarn build` fresh inside the image, so none of the
# host's installed/built artifacts should be shipped into the context.

# deps + build output (regenerated in-image)
node_modules
.next
out
build
dist
*.tsbuildinfo
next-env.d.ts

# env & secrets — NEVER bake into an image layer (the YouTube key arrives as a --build-arg)
.env
.env*.local
.env.production
*.pem

# vcs / CI / deploy config (not needed to build the app)
.git
.github
deploy
Dockerfile
.dockerignore

# tests / coverage / reports (not part of the runtime image)
test
test-results
playwright-report
coverage
e2e
# The Playwright config lives at the repo root (so it isn't caught by `e2e` above), but it
# imports from ./e2e (stripped above) and Playwright never runs inside the production image.
# Excluding it keeps the build context minimal AND stops `next build`'s project-wide
# type-check from choking on the now-unresolvable ./e2e/db-server import (issue #47 fix).
playwright.config.ts

# Dev-only tooling (the screenshot harness, the QA gate, test-db helpers) — never part of the
# production image. Same reasoning as playwright.config.ts above: scripts/dev/shots-index.ts
# imports from the ./e2e catalog (stripped above), so leaving it in the context breaks
# `next build`'s project-wide type-check. The build-time scripts (build-migrate.mjs, migrate.ts,
# seed.ts, ops/) live at scripts/ root and stay in the context.
scripts/dev

# docs, mockups, agent config — not part of the app build
docs
mockups
.claude

# os / editor
.DS_Store
Thumbs.db
.idea
.vscode
*.swp

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# dependencies
node_modules
node_modules/
.pnp
.pnp.*

# next.js / build output
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# env & secrets
.env
.env*.local
.env.production
*.pem
# Docker secret files (e.g. deploy/secrets/postgres_password) — never commit secrets
deploy/secrets/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local data volumes (docker)
/pgdata/
/redis-data/

# os / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# test / coverage
coverage/
test-results/
playwright-report/

# scripts/dev/shoot.sh + shots.sh default output dirs (gitignored captures). Anchored to the repo
# root so it never swallows the committed e2e/screenshots/ catalog or a docs/design/ gallery.
/screenshots/

# Build worktrees (scripts/dev/worktree.sh) live under the repo root so reads/writes into them
# inherit the trusted-directory grant (no per-worktree permission prompt); they must never be tracked.
.claude/worktrees/
